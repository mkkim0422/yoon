# [Streamlit 웹 설정]
STREAMLIT_SERVER_PORT=8501
STREAMLIT_THEME_BASE=light

# [Billing Data 설정]
MASTER_DATA_PATH=billing/master_data.csv

# [이메일 자동 발송 설정 (향후 구현 예정)]
# SMTP 서버 설정 (예: Gmail, Outlook 등)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@sphinfo.co.kr
# 실제 비밀번호는 절대 깃허브나 외부로 유출되지 않도록 주의할 것 (.env에만 기록)
SMTP_PASSWORD=your_app_password_here
